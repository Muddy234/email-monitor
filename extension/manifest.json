{
  "manifest_version": 3,
  "name": "Email Monitor — Outlook Bridge",
  "version": "1.0.0",
  "description": "Bridges Outlook Online with the Email Monitor pipeline via WebSocket.",

  "permissions": [
    "alarms",
    "storage"
  ],

  "host_permissions": [
    "*://outlook.cloud.microsoft/*",
    "*://outlook.live.com/*",
    "*://outlook.office365.com/*",
    "*://outlook.office.com/*",
    "http://localhost/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://outlook.cloud.microsoft/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
