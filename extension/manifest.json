{
  "manifest_version": 3,
  "name": "Clarion AI",
  "short_name": "Clarion",
  "version": "1.0.0",
  "description": "Syncs your Outlook emails for AI-powered analysis and draft generation.",
  "homepage_url": "https://clarion-ai.app",

  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "https://outlook.cloud.microsoft/*",
    "https://outlook.live.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.office.com/*",
    "https://frbvdoszenrrlswegsxq.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://outlook.cloud.microsoft/*",
        "https://outlook.live.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.office.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
